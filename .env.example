# Copy to .env and adjust. Read by docker compose and (optionally) the app.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trucks

# Connection string used by the app / pipeline.
# - From the host (pipeline runs, scripts/init_db.py): host is localhost
# - From inside the web container: host is "db" (the compose service name)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/trucks

# Admin login for the telecaller review page (/review) and the review PATCH endpoint.
# CHANGE THIS before deploying — it gates reward approval.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Host folder containing the videos to process (mounted into the pipeline container).
# Videos are NOT in the repo/image — point this at wherever your footage lives.
VIDEOS_DIR=./videos

# Production HTTPS (docker-compose.prod.yml + Caddy). The domain whose DNS A-record
# points at the server's public IP; Caddy auto-issues a Let's Encrypt cert for it.
# A free subdomain works (e.g. DuckDNS): DOMAIN=freightdesk.duckdns.org
DOMAIN=

# Host port bindings. Only matter for direct host access — the web container always
# reaches Postgres internally at db:5432. On a SHARED VM where 8000/5432 are already
# taken by other containers, set these to FREE ports (check: sudo ss -tlnp | grep :PORT).
#   Quick HTTP test via the VM's IP:   WEB_BIND=0.0.0.0:8090
#   Behind Caddy/Traefik/nginx:        leave default (localhost) — the proxy routes internally.
WEB_BIND=127.0.0.1:8000
DB_BIND=127.0.0.1:5432
